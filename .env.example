# Allowed CORS origin for your frontend
FRONT_ORIGIN=https://your-frontend.example.com

# Admin key for protected endpoints (used via header X-Admin-Key)
# Generate a strong random value and DO NOT commit the real key
WHATSAPP_ADMIN_KEY=change-me-strong-secret

# Node environment
NODE_ENV=production

# Optional: Render provides PORT automatically; keep for local use
PORT=3030

# Optional: Webhook URL to forward incoming WhatsApp messages (e.g. bot integration)
# If not set, incoming messages are ignored (safe for send-only usage)
WEBHOOK_URL=
# Secret sent as X-Webhook-Secret header to authenticate webhook calls
WEBHOOK_SECRET=
